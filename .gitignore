```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual Environment
# =========================
venv/
.venv/
env/
ENV/

# =========================
# Build
# =========================
build/
dist/
*.egg-info/
.eggs/

# =========================
# Jupyter Notebook
# =========================
.ipynb_checkpoints/

# =========================
# Environment Variables
# =========================
.env
.env.*

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# ML Artifacts
# =========================
artifacts/

# =========================
# Pytest
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# MyPy
# =========================
.mypy_cache/

# =========================
# Ruff
# =========================
.ruff_cache/

# =========================
# VS Code
# =========================
.vscode/

# =========================
# PyCharm
# =========================
.idea/

# =========================
# macOS
# =========================
.DS_Store

# =========================
# Windows
# =========================
Thumbs.db
desktop.ini

# =========================
# Temporary Files
# =========================
*.tmp
*.temp
*.bak
*.swp
```
